{
  "name": "rust-assembly-line",
  "version": "0.1.0",
  "description": "A Rust software assembly line: ADR authoring, planning, implementation, and quality gates for Rust workspace projects.",
  "commands": [
    {
      "name": "adr",
      "description": "Author and validate an Architecture Decision Record (ADR) for a Rust feature",
      "path": "commands/adr.md"
    },
    {
      "name": "plan",
      "description": "Transform an ADR into Linear issues with Rust crate-layer dependencies",
      "path": "commands/plan.md"
    },
    {
      "name": "work",
      "description": "Pick the next unblocked story and implement it with Rust quality gates",
      "path": "commands/work.md"
    },
    {
      "name": "review",
      "description": "Run multi-agent Rust code review on the current branch or PR",
      "path": "commands/review.md"
    },
    {
      "name": "compound",
      "description": "Review the session, capture Rust learnings, and update project documentation",
      "path": "commands/compound.md"
    },
    {
      "name": "scaffold",
      "description": "Generate a complete CRUD scaffold for an entity across Rust crate layers",
      "path": "commands/scaffold.md"
    },
    {
      "name": "es-scaffold",
      "description": "Generate an Event Sourcing scaffold using domain aggregates and fold→decide→evolve with Functional Core / Imperative Shell architecture",
      "path": "commands/es-scaffold.md"
    },
    {
      "name": "setup",
      "description": "Install rust-assembly-line hooks and quality gates into the current project",
      "path": "commands/setup.md"
    }
  ],
  "agents": [
    {
      "name": "planning:adr-structure-validator",
